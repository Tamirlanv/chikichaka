{
  "name": "certificate-validation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:legal": "vitest run --config vitest.integration.config.ts src/services/__tests__/legalFixtures.integration.test.ts",
    "test:legal:ci": "LEGAL_SKIP_OCR_FIXTURES=1 vitest run --config vitest.integration.config.ts src/services/__tests__/legalFixtures.integration.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^5.2.1",
    "openai": "^4.104.0",
    "pg": "^8.13.1",
    "sharp": "^0.34.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.11",
    "pdf-parse": "^2.4.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
